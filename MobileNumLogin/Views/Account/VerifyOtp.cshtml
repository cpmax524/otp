<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OTP Verification - Your App</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/custom-styles.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container-fluid vh-100 d-flex align-items-center justify-content-center">
        <div class="row w-100">
            <div class="col-md-6 col-lg-4 mx-auto">
                <div class="card shadow-lg border-0 rounded-4">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <div class="otp-icon mb-3">
                                <i class="fas fa-mobile-alt text-primary" style="font-size: 3rem;"></i>
                            </div>
                            <h2 class="fw-bold text-primary">Verify OTP</h2>
                            <p class="text-muted">Enter the 6-digit code sent to</p>
                            <p class="fw-semibold text-dark" id="phoneDisplay">+91 XXXXXXXXXX</p>
                        </div>

                        <form id="otpForm">
                            <div class="mb-4">
                                <label class="form-label fw-semibold text-center d-block mb-3">Enter OTP</label>
                                <div class="otp-input-container d-flex justify-content-center gap-2">
                                    <input type="text" class="form-control otp-input text-center" maxlength="1" data-index="0">
                                    <input type="text" class="form-control otp-input text-center" maxlength="1" data-index="1">
                                    <input type="text" class="form-control otp-input text-center" maxlength="1" data-index="2">
                                    <input type="text" class="form-control otp-input text-center" maxlength="1" data-index="3">
                                    <input type="text" class="form-control otp-input text-center" maxlength="1" data-index="4">
                                    <input type="text" class="form-control otp-input text-center" maxlength="1" data-index="5">
                                </div>
                                <div class="invalid-feedback text-center mt-2">
                                    Please enter the complete OTP.
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100 mb-3" id="verifyOtpBtn">
                                <span class="btn-text">Verify OTP</span>
                                <span class="spinner-border spinner-border-sm d-none ms-2" role="status"></span>
                            </button>

                        </form>

                        <div class="text-center">
                            <p class="mb-2">Didn't receive the code?</p>
                            <button class="btn btn-link text-primary fw-semibold p-0" id="resendOtpBtn">
                                Resend OTP <span id="resendTimer"></span>
                            </button>
                        </div>

                        <div class="text-center mt-3">
                            <a href="/Account/Login" class="text-muted text-decoration-none">
                                <i class="fas fa-arrow-left me-1"></i> Back to Login
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <div id="customToast" class="toast" role="alert">
            <div class="toast-header">
                <div class="toast-icon me-2"></div>
                <strong class="me-auto toast-title">Notification</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body"></div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/js/all.min.js"></script>
    <script src="~/js/otp-verification.js"></script>
</body>
</html>
