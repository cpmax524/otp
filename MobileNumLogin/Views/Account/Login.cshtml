<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Your App</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/custom-styles.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container-fluid vh-100 d-flex align-items-center justify-content-center">
        <div class="row w-100">
            <div class="col-md-6 col-lg-4 mx-auto">
                <div class="card shadow-lg border-0 rounded-4">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <h2 class="fw-bold text-primary">Welcome Back</h2>
                            <p class="text-muted">Enter your phone number to continue</p>
                        </div>

                        <form id="loginForm">
                            <div class="mb-4">
                                <label for="phoneNumber" class="form-label fw-semibold">Phone Number</label>
                                <input type="tel" class="form-control form-control-lg" id="phoneNumber"
                                       placeholder="Enter your 10-digit phone number" maxlength="10">
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100 mb-3" id="getOtpBtn">
                                <span class="btn-text">Get OTP</span>
                                <span class="spinner-border spinner-border-sm d-none" role="status"></span>
                            </button>
                        </form>

                        <div class="text-center">
                            <p class="mb-0">
                                Don't have an account?
                                <a href="/Account/Register" class="text-primary fw-semibold text-decoration-none">Sign up</a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <div id="customToast" class="toast" role="alert">
            <div class="toast-header">
                <div class="toast-icon me-2"></div>
                <strong class="me-auto toast-title">Notification</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body"></div>
        </div>
    </div>

    <!-- Server-side messages for JavaScript -->
    @if (ViewData.ModelState.Any(x => x.Value.Errors.Count > 0))
    {
        <script>
            window.serverMessages = {
                errors: @Html.Raw(Json.Serialize(ViewData.ModelState.SelectMany(x => x.Value.Errors).Select(x => x.ErrorMessage)))
            };
        </script>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            window.serverMessages = window.serverMessages || {};
            window.serverMessages.success = '@TempData["SuccessMessage"]';
        </script>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            window.serverMessages = window.serverMessages || {};
            window.serverMessages.error = '@TempData["ErrorMessage"]';
        </script>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/login.js"></script>
</body>
</html>
